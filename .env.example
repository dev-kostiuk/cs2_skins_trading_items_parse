# ── DMarket items ─────────────────────────────────────────────
# Публічний API — авторизація не потрібна
DMARKET_URL=https://api.dmarket.com/exchange/v1/market/items
DMARKET_GAME_ID=a8db
DMARKET_CURRENCY=USD

DMARKET_LIMIT=100
DMARKET_MAX_PAGES=1000

DMARKET_HTTP_MAX_RETRIES=8
DMARKET_PAGE_DELAY_MS=250
DMARKET_MAX_WAIT_MS=15000
DMARKET_FETCH_TOTAL_TIMEOUT_MS=30000

# Пауза між повними оновленнями каталогу (мс)
DMARKET_LOOP_SLEEP_MS=60000
DMARKET_EMPTY_SLEEP_MS=300000

# Шляхи до БД (відносно папки items_parse/)
DMARKET_ITEMS_DB_PATH=../database/items.db
DMARKET_ITEMS_DMARKET_DB_PATH=../database/items_dmarket.db

DMARKET_BUSY_TIMEOUT_MS=5000

# ── Whitemarket items ──────────────────────────────────────────
# Публічний S3 JSON — авторизація не потрібна
# Файл оновлюється на стороні white.market раз на годину
WHITEMARKET_URL=https://s3.white.market/export/v1/prices/730.json

WHITEMARKET_HTTP_MAX_RETRIES=8
WHITEMARKET_MAX_WAIT_MS=15000
WHITEMARKET_FETCH_TOTAL_TIMEOUT_MS=60000

# Оновлювати раз на годину (частіше немає сенсу)
WHITEMARKET_LOOP_SLEEP_MS=3600000
WHITEMARKET_EMPTY_SLEEP_MS=3600000

WHITEMARKET_ITEMS_DB_PATH=../database/items.db
WHITEMARKET_ITEMS_WHITEMARKET_DB_PATH=../database/items_whitemarket.db

WHITEMARKET_BUSY_TIMEOUT_MS=5000
